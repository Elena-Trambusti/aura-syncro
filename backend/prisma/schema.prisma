generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== FISCALITÀ MULTI-NAZIONE =====
enum CountryCode {
  IT
  ES
}

enum TaxRegion {
  IT_MAIN
  ES_CANARIAS
  ES_PENINSULA
}

/**
 * Regime fiscale normalizzato (AgID IT / Ley Antifraude ES)
 */
enum FiscalRegion {
  ITALIA
  SPAGNA_PENINSULA
  ISOLE_CANARIE
}

enum PlanTier {
  BASE
  PRO
}

/**
 * Integrazione POS fisico — configurata in fase di setup concierge per ogni ristorante
 */
enum PosIntegrationMode {
  PENDING_SETUP // Post-pagamento: POS non ancora collegato
  SIMULATION // Solo demo/formazione — ricevute non legali
  STRIPE_TERMINAL // Stripe Terminal / PaymentIntent
  EXTERNAL // Registratore di cassa esterno — incasso sul loro hardware
}

enum SubscriptionPlan {
  STARTER
  PREMIUM
}

// ===== RISTORANTE =====
model Restaurant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  colorTheme       String           @default("#c9a227")
  logoUrl          String?
  address          String?
  phone            String?
  email            String?
  logo             String?
  coverImage       String?
  description      String?
  currency         String           @default("EUR")
  timezone         String           @default("Europe/Rome")
  /**
   * Concierge onboarding completato dal team Aura Syncro
   */
  isSetupComplete  Boolean          @default(false)
  subscriptionPlan SubscriptionPlan @default(STARTER)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  users                  User[]
  tables                 Table[]
  menuCategories         MenuCategory[]
  menuItems              MenuItem[]
  orders                 Order[]
  reservations           Reservation[]
  customers              Customer[]
  shifts                 Shift[]
  inventory              InventoryItem[]
  settings               RestaurantSettings?
  loyaltyTiers           LoyaltyTier[]
  campaigns              Campaign[]
  marketingAutomations   MarketingAutomation[]
  marketingAutomationSends MarketingAutomationSend[]
  waitlist               WaitlistEntry[]
  invoices               Invoice[]
  fiscalSequences        FiscalSequence[]
  cashRegisterSessions   CashRegisterSession[]
  fiscalChainState       FiscalChainState?
  stripeWebhookEvents    StripeWebhookEvent[]
  saasElectronicInvoices SaasElectronicInvoice[]
  apiIdempotencyRecords  ApiIdempotencyRecord[]
  fiscalClosures         FiscalClosure[]
  setupAppointment       SetupAppointment?
}

/**
 * Appuntamento setup concierge — sostituto Calendly (slot globali unici)
 */
model SetupAppointment {
  id           String                   @id @default(cuid())
  restaurantId String                   @unique
  restaurant   Restaurant               @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  slotStart    DateTime
  slotEnd      DateTime
  status       SetupAppointmentStatus   @default(CONFIRMED)
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@unique([slotStart])
  @@index([slotStart, status])
}

enum SetupAppointmentStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model FiscalClosure {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  date         DateTime   @default(now())
  /** Giorno calendario tenant (YYYY-MM-DD) — vincolo unicità anti-race Zeta */
  calendarDay  String

  totalRevenue Decimal @default(0) @db.Decimal(12, 2) // Incasso lordo totale
  totalTax     Decimal @default(0) @db.Decimal(12, 2) // IVA totale
  totalCash    Decimal @default(0) @db.Decimal(12, 2) // Totale contanti dichiarati o calcolati
  totalCard    Decimal @default(0) @db.Decimal(12, 2) // Totale carte POS fisico
  totalStripe  Decimal @default(0) @db.Decimal(12, 2)
  totalDigital Decimal @default(0) @db.Decimal(12, 2)
  totalVoucher Decimal @default(0) @db.Decimal(12, 2)
  totalTip     Decimal @default(0) @db.Decimal(12, 2) // Mance totali

  orderCount Int // Numero di ordini chiusi
  status     String  @default("GENERATED") // GENERATED, TRANSMITTED, ERROR
  arubaXmlId String? // ID eventuale fattura/corrispettivo Aruba

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, calendarDay])
  @@index([restaurantId])
}

/**
 * Risposte cache per X-Idempotency-Key (retry offline / doppio tap)
 */
model ApiIdempotencyRecord {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  key          String
  route        String
  statusCode   Int
  responseBody Json
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, key])
  @@index([createdAt])
}

model RestaurantSettings {
  id                      String             @id @default(cuid())
  restaurantId            String             @unique
  restaurant              Restaurant         @relation(fields: [restaurantId], references: [id])
  openTime                String             @default("12:00")
  closeTime               String             @default("23:00")
  maxCoversPerSlot        Int                @default(20)
  reservationSlotMinutes  Int                @default(90)
  countryCode             CountryCode        @default(IT)
  taxRegion               TaxRegion          @default(IT_MAIN)
  /**
   * Regime fiscale unificato (IT / ES penisola / Canarie)
   */
  fiscalRegion            FiscalRegion       @default(ITALIA)
  defaultLocale           String             @default("it")
  taxRate                 Float              @default(10.0)
  serviceCharge           Decimal            @default(0) @db.Decimal(12, 2)
  autoConfirmReservations Boolean            @default(true)
  noShowDepositRequired   Boolean            @default(false)
  depositAmount           Decimal            @default(0) @db.Decimal(12, 2)
  taxId                   String?
  /**
   * Ragione sociale per fatturazione elettronica
   */
  legalName               String?
  /**
   * Indirizzo legale della sede fiscale
   */
  legalAddress            String?
  /**
   * Coordinate per previsioni meteo (Open-Meteo)
   */
  latitude                Float?
  longitude               Float?
  /**
   * Codice fiscale (Italia)
   */
  fiscalCode              String?
  /**
   * PEC per fatturazione elettronica
   */
  pec                     String?
  /**
   * Codice destinatario SDI (7 caratteri, es. M5UXCR1)
   */
  sdiRecipientCode        String?
  /**
   * Prefisso numerazione documenti (es. FATT → FATT-2026-001)
   */
  invoicePrefix           String             @default("FATT")
  /**
   * Abbonamento SaaS Aura Syncro Premium
   */
  hasActiveSubscription   Boolean            @default(false)
  /**
   * Cliente Stripe collegato al tenant (fatturazione SaaS)
   */
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  /**
   * Abbonamento add-on piano Pro (CRM, AI, marketing…)
   */
  stripeProSubscriptionId String?
  /**
   * Piano moduli: BASE (core POS) o PRO (CRM, AI, marketing, fiscal…)
   */
  planTier                PlanTier           @default(BASE)
  /**
   * POS fisico / registratore — configurato dal team in onboarding
   */
  posIntegrationMode      PosIntegrationMode @default(PENDING_SETUP)
  /**
   * Marca/modello POS (es. Nexi, SumUp, Custom) — compilato in setup
   */
  posProviderLabel        String?
  posTerminalId           String?
  posMerchantId           String?
  posSetupNotes           String?
  posConfiguredAt         DateTime?
  /**
   * Account Stripe Connect del ristorante (Express) per ricevere pagamenti diretti
   */
  stripeConnectAccountId  String?
  /**
   * Tariffa oraria stimata per report P&L (€/h)
   */
  laborHourlyRate         Float              @default(12)
  /**
   * Sede fiscale — dettaglio per XML fatture B2B
   */
  legalCity               String?
  legalZip                String?
  legalProvince           String?
  /**
   * Checklist concierge onboarding (persistita)
   */
  onboardingConcierge     Json?
  /**
   * Payload completo modulo onboarding proprietario (sala, menu, hardware…)
   */
  onboardingIntake        Json?
  onboardingSubmittedAt   DateTime?
  /**
   * Telegram Chat ID associato al tenant per ricezione alert AI
   */
  telegramChatId          String?
  /**
   * Layout 2.5D sala: muri, etichette zona, percorsi (JSON versionato v1)
   */
  floorPlanLayout         Json?
  /**
   * Token segreto per pairing Print Agent locale (ESC/POS)
   */
  printAgentToken         String?
}

// ===== UTENTI =====
model User {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  email        String
  password     String
  role         Role       @default(WAITER)
  avatar       String?
  phone        String?
  active       Boolean    @default(true)
  tokenVersion Int        @default(0)
  /** Accettazione Termini / DPA in registrazione */
  termsAcceptedAt      DateTime?
  termsVersion         String?
  dpaAcceptedAt        DateTime?
  dpaVersion           String?
  legalAcceptIp        String?
  legalAcceptUserAgent String?    @db.VarChar(512)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  orders             Order[]               @relation("OrderWaiter")
  tipOrders          Order[]               @relation("TipWaiter")
  shifts             Shift[]
  pushSubscriptions  PushSubscription[]
  openedCashSessions CashRegisterSession[] @relation("OpenedSessions")
  closedCashSessions CashRegisterSession[] @relation("ClosedSessions")
  cashTransactions   CashTransaction[]
  inventoryAdjustments InventoryAdjustment[]

  @@unique([restaurantId, email])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  endpoint     String
  p256dh       String
  auth         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([restaurantId])
}

enum Role {
  OWNER
  MANAGER
  WAITER
  CHEF
  BARTENDER
  HOST
}

// ===== TAVOLI =====
model Table {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  number       Int
  name         String?
  seats        Int         @default(4)
  status       TableStatus @default(FREE)
  posX         Float       @default(0)
  posY         Float       @default(0)
  shape        TableShape  @default(SQUARE)
  rotation     Int         @default(0)
  area         String?
  qrCode       String?
  /** Cameriere che ha preso in carico il tavolo (lock sala) */
  servingUserId    String?
  servingUserName  String?
  servingClaimedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders       Order[]
  reservations Reservation[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
}

enum TableShape {
  SQUARE
  ROUND
  RECTANGLE
  BAR_STOOL
  BOOTH
}

// ===== MENU =====
model MenuCategory {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  description  String?
  image        String?
  sortOrder    Int        @default(0)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  items MenuItem[]
}

model MenuItem {
  id              String       @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant   @relation(fields: [restaurantId], references: [id])
  categoryId      String
  category        MenuCategory @relation(fields: [categoryId], references: [id])
  name            String
  description     String?
  price           Decimal      @db.Decimal(12, 2)
  /**
   * Aliquota IVA/IGIC applicata al piatto (es. 4, 10, 22 IT). Null = default locale.
   */
  taxRate         Float?
  image           String?
  allergens       String?
  calories        Int?
  preparationTime Int?
  available       Boolean      @default(true)
  featured        Boolean      @default(false)
  /**
   * true = rimosso dal menu ma conservato per storico ordini
   */
  archived        Boolean      @default(false)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  orderItems     OrderItem[]
  inventoryLinks InventoryItemLink[]
  modifierGroups MenuModifierGroup[]
}

model MenuModifierGroup {
  id          String   @id @default(cuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name        String
  isRequired  Boolean  @default(false)
  multiSelect Boolean  @default(false)
  minOptions  Int      @default(0)
  maxOptions  Int?
  sortOrder   Int      @default(0)

  options MenuModifierOption[]
}

model MenuModifierOption {
  id        String            @id @default(cuid())
  groupId   String
  group     MenuModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal           @default(0) @db.Decimal(12, 2)
  sortOrder Int               @default(0)
}

// ===== ORDINI =====
model Order {
  id                   String         @id @default(cuid())
  restaurantId         String
  restaurant           Restaurant     @relation(fields: [restaurantId], references: [id])
  tableId              String?
  table                Table?         @relation(fields: [tableId], references: [id])
  waiterId             String?
  waiter               User?          @relation("OrderWaiter", fields: [waiterId], references: [id])
  customerId           String?
  customer             Customer?      @relation(fields: [customerId], references: [id])
  status               OrderStatus    @default(PENDING)
  type                 OrderType      @default(DINE_IN)
  notes                String?
  subtotal             Decimal        @default(0) @db.Decimal(12, 2)
  tax                  Decimal        @default(0) @db.Decimal(12, 2)
  taxRateApplied       Float?
  serviceCharge        Decimal        @default(0) @db.Decimal(12, 2)
  discount             Decimal        @default(0) @db.Decimal(12, 2)
  total                Decimal        @default(0) @db.Decimal(12, 2)
  revenueAmount        Decimal        @default(0) @db.Decimal(12, 2)
  tipAmount            Decimal        @default(0) @db.Decimal(12, 2)
  tipWaiterId          String?
  tipWaiter            User?          @relation("TipWaiter", fields: [tipWaiterId], references: [id])
  paidAt               DateTime?
  paymentMethod        PaymentMethod?
  stripeSessionId      String?
  stripePaymentIntent  String?
  /**
   * Snapshot dati fatturazione B2B al momento del pagamento
   */
  billingLegalName     String?
  billingTaxId         String?
  billingFiscalCode    String?
  billingSdiCode       String?
  billingPec           String?
  /**
   * Snapshot regime fiscale alla chiusura (immutabile)
   */
  fiscalRegionSnapshot FiscalRegion?
  /**
   * Hash SHA-256 catena VeriFactu / anti-frode (immutabile dopo PAID)
   */
  fiscalIntegrityHash  String?        @unique
  /**
   * Hash ordine precedente nella catena del locale
   */
  fiscalPrevHash       String?
  /**
   * Timestamp certificato di chiusura conto
   */
  fiscalClosedAt       DateTime?
  /**
   * Rimborso registrato — escluso dai KPI revenue
   */
  refundedAt           DateTime?
  refundAmount         Decimal        @default(0) @db.Decimal(12, 2)
  /** Incasso cumulativo split conto (quote parziali prima di PAID) */
  collectedAmount      Decimal        @default(0) @db.Decimal(12, 2)
  /** Indici ospiti split già saldati (0-based) */
  splitPaidGuestIndexes Int[]         @default([])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  items            OrderItem[]
  invoice          Invoice?
  cashTransactions CashTransaction[]

  @@index([restaurantId, status, paidAt])
  @@index([restaurantId, createdAt])
  @@index([tableId, status])
}

model OrderItem {
  id                String     @id @default(cuid())
  orderId           String
  order             Order      @relation(fields: [orderId], references: [id])
  menuItemId        String
  menuItem          MenuItem   @relation(fields: [menuItemId], references: [id])
  quantity          Int        @default(1)
  unitPrice         Decimal    @db.Decimal(12, 2)
  course            Int        @default(1)
  notes             String?
  status            ItemStatus @default(PENDING)
  /**
   * Ingredienti già scalati dal magazzino per questa riga
   */
  inventoryDeducted Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([menuItemId, createdAt])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  optionId    String?
  name        String
  price       Decimal   @db.Decimal(12, 2)
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  PAID
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum ItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  VOUCHER
  DIGITAL
  STRIPE
}

// ===== PRENOTAZIONI =====
model Reservation {
  id                     String            @id @default(cuid())
  restaurantId           String
  restaurant             Restaurant        @relation(fields: [restaurantId], references: [id])
  tableId                String?
  table                  Table?            @relation(fields: [tableId], references: [id])
  customerId             String?
  customer               Customer?         @relation(fields: [customerId], references: [id])
  guestName              String
  guestPhone             String
  guestEmail             String?
  covers                 Int               @default(2)
  date                   DateTime
  duration               Int               @default(90)
  status                 ReservationStatus @default(CONFIRMED)
  notes                  String?
  internalNotes          String?
  reminderSent           Boolean           @default(false)
  depositPaid            Boolean           @default(false)
  depositStripeSessionId String?
  depositAmountPaid      Decimal?          @db.Decimal(12, 2)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([restaurantId, date])
  @@index([tableId, date, status])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ===== CLIENTI (CRM) =====
model Customer {
  id               String       @id @default(cuid())
  restaurantId     String
  restaurant       Restaurant   @relation(fields: [restaurantId], references: [id])
  firstName        String       @default("")
  lastName         String       @default("")
  name             String
  email            String?
  phone            String?
  birthdate        DateTime?
  notes            String?
  allergens        String?
  tags             String[]     @default([])
  loyaltyPoints    Int          @default(0)
  totalVisits      Int          @default(0)
  totalSpent       Decimal      @default(0) @db.Decimal(12, 2)
  lastVisit        DateTime?
  /**
   * P.IVA / NIF cliente (fatturazione B2B)
   */
  taxId            String?
  /**
   * Codice fiscale (Italia)
   */
  fiscalCode       String?
  /**
   * Codice destinatario SDI (7 caratteri)
   */
  sdiRecipientCode String?
  /**
   * PEC cliente
   */
  pec              String?
  loyaltyTierId    String?
  loyaltyTier      LoyaltyTier? @relation(fields: [loyaltyTierId], references: [id])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  orders              Order[]
  reservations        Reservation[]
  loyaltyTransactions LoyaltyTransaction[]
  marketingAutomationSends MarketingAutomationSend[]

  @@unique([restaurantId, email])
  @@index([restaurantId])
}

// ===== PERSONALE - TURNI =====
model Shift {
  id           String      @id @default(cuid())
  restaurantId String
  restaurant   Restaurant  @relation(fields: [restaurantId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  date         DateTime
  startTime    String
  endTime      String
  role         String?
  notes        String?
  status       ShiftStatus @default(SCHEDULED)
  clockIn      DateTime?
  clockOut     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  ABSENT
}

// ===== GESTIONE CASSA (CASH DRAWER) =====
model CashRegisterSession {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  openedById   String
  openedBy     User       @relation("OpenedSessions", fields: [openedById], references: [id])
  closedById   String?
  closedBy     User?      @relation("ClosedSessions", fields: [closedById], references: [id])

  openedAt DateTime  @default(now())
  closedAt DateTime?

  status CashSessionStatus @default(OPEN)

  // Importi in contanti (tutto in valuta locale)
  openingBalance  Decimal  @default(0) @db.Decimal(12, 2) // Fondo cassa iniziale
  closingBalance  Decimal? @db.Decimal(12, 2) // Il contante contato a fine turno (Blind Drop)
  expectedBalance Decimal? @db.Decimal(12, 2) // Il contante atteso calcolato dal sistema
  difference      Decimal? @db.Decimal(12, 2) // closingBalance - expectedBalance (se < 0 c'è un ammanco)

  notes String?

  transactions CashTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

model CashTransaction {
  id        String              @id @default(cuid())
  sessionId String
  session   CashRegisterSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id])

  type   CashTransactionType // PAYIN, PAYOUT, SALE, REFUND
  amount Decimal @db.Decimal(12, 2) // Deve essere positivo
  reason String?

  // Se legato a un ordine specifico
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

enum CashTransactionType {
  PAYIN
  PAYOUT
  SALE
  REFUND
}

// ===== FEDELTÀ =====
model LoyaltyTier {
  id            String     @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  name          String
  minPoints     Int        @default(0)
  color         String     @default("#94a3b8")
  benefits      String?
  discountPct   Float      @default(0)
  cashbackPct   Float      @default(0)
  pointsPerEuro Float      @default(1)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  customers Customer[]
}

model LoyaltyTransaction {
  id           String                 @id @default(cuid())
  restaurantId String
  customerId   String
  customer     Customer               @relation(fields: [customerId], references: [id])
  type         LoyaltyTransactionType
  points       Int
  description  String?
  orderId      String?
  createdAt    DateTime               @default(now())
}

enum LoyaltyTransactionType {
  EARNED
  REDEEMED
  EXPIRED
  BONUS
  ADJUSTMENT
}

// ===== MARKETING =====
model Campaign {
  id             String         @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id])
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  subject        String?
  message        String
  targetFilter   String?
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int            @default(0)
  discountCode   String?
  discountPct    Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum CampaignType {
  EMAIL
  SMS
  BIRTHDAY
  WIN_BACK
  PROMOTION
  NEWS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum AutomationType {
  BIRTHDAY
  WIN_BACK
  VIP_THANKS
  REQUEST_REVIEW
}

model MarketingAutomation {
  id              String         @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant     @relation(fields: [restaurantId], references: [id])
  type            AutomationType
  isActive        Boolean        @default(false)
  messageTemplate String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([restaurantId, type])
}

model MarketingAutomationSend {
  id             String         @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  automationType AutomationType
  customerId     String
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  calendarDay    String
  createdAt      DateTime       @default(now())

  @@unique([restaurantId, automationType, customerId, calendarDay])
  @@index([restaurantId, calendarDay])
}

// ===== LISTA D'ATTESA =====
model WaitlistEntry {
  id            String         @id @default(cuid())
  restaurantId  String
  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  guestName     String
  guestPhone    String
  guestEmail    String?
  covers        Int            @default(2)
  requestedDate DateTime
  notes         String?
  status        WaitlistStatus @default(WAITING)
  notifiedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  EXPIRED
  CANCELLED
}

// ===== INVENTARIO =====
model InventoryItem {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  name         String
  unit         String
  quantity     Float      @default(0)
  minQuantity  Float      @default(0)
  cost         Decimal    @default(0) @db.Decimal(12, 2)
  supplier     String?
  category     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  menuLinks     InventoryItemLink[]
  adjustments   InventoryAdjustment[]

  @@index([restaurantId])
}

model InventoryAdjustment {
  id              String        @id @default(cuid())
  restaurantId    String
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  delta           Float
  quantityBefore  Float
  quantityAfter   Float
  reason          String?
  createdAt       DateTime      @default(now())

  @@index([restaurantId, inventoryItemId])
}

model InventoryItemLink {
  id              String        @id @default(cuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Float         @default(1)

  @@unique([menuItemId, inventoryItemId])
}

// ===== FATTURAZIONE (preparazione SDI / Registratori Telematici) =====

/**
 * Contatore progressivo annuale per ristorante (thread-safe via transazione).
 */
/**
 * Stato testa catena crittografica VeriFactu / anti-frode per tenant
 */
model FiscalChainState {
  restaurantId String     @id
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  lastHash     String     @default("GENESIS")
  lastOrderId  String?
  updatedAt    DateTime   @updatedAt
}

model FiscalSequence {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  fiscalYear   Int
  lastSequence Int        @default(0)
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, fiscalYear])
}

/**
 * Documento fiscale emesso al pagamento (es. FATT-2026-001).
 */
model Invoice {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  orderId        String?    @unique
  order          Order?     @relation(fields: [orderId], references: [id])
  /**
   * Numero leggibile: {prefix}-{anno}-{seq}
   */
  documentNumber String
  prefix         String     @default("FATT")
  fiscalYear     Int
  sequence       Int
  issuedAt       DateTime   @default(now())

  // Dati Fatturazione Elettronica B2B
  clientePiva           String?
  clienteCodiceFiscale  String?
  clienteSdiCode        String?
  clientePec            String?
  clienteRagioneSociale String?
  clienteIndirizzo      String?

  importoTotale Decimal   @default(0) @db.Decimal(12, 2)
  statoSdi      String  @default("pending") // pending, sent, delivered, rejected
  xmlBlob       String? @db.Text
  arubaUploadId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, fiscalYear, sequence])
  @@unique([restaurantId, documentNumber])
  @@index([restaurantId, issuedAt])
}

// ===== FATTURAZIONE ELETTRONICA SAAS (Aura Syncro → ristoranti) =====

enum StripeWebhookStatus {
  processing
  succeeded
  failed
}

enum SaasElectronicInvoiceStatus {
  pending
  sent
  failed
}

/**
 * Ledger idempotenza eventi Stripe (evt_xxx)
 */
model StripeWebhookEvent {
  id            String              @id @default(cuid())
  stripeEventId String              @unique
  type          String
  livemode      Boolean             @default(false)
  status        StripeWebhookStatus @default(processing)
  restaurantId  String?
  restaurant    Restaurant?         @relation(fields: [restaurantId], references: [id])
  metadata      Json?
  errorMessage  String?
  processedAt   DateTime?
  createdAt     DateTime            @default(now())

  @@index([type, createdAt])
  @@index([restaurantId])
}

/**
 * Fattura elettronica emessa ad Aruba/SDI per pagamento abbonamento SaaS
 */
model SaasElectronicInvoice {
  id                  String                      @id @default(cuid())
  restaurantId        String?
  restaurant          Restaurant?                 @relation(fields: [restaurantId], references: [id])
  stripeInvoiceId     String                      @unique
  stripeCustomerId    String?
  stripeEventId       String?
  status              SaasElectronicInvoiceStatus @default(pending)
  fiscalRegime        String
  legalName           String
  vatNumber           String
  sdiRecipientCode    String?
  pec                 String?
  billingAddress      Json
  netAmount           Decimal @db.Decimal(12, 2)
  taxAmount           Decimal @db.Decimal(12, 2)
  grossAmount         Decimal @db.Decimal(12, 2)
  taxRate             Float
  vatNature           String?
  currency            String                      @default("EUR")
  arubaUploadFileName String?
  arubaErrorCode      String?
  arubaErrorMessage   String?
  sentAt              DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([restaurantId, createdAt])
  @@index([status])
}

/** Audit trail operazioni sensibili (pagamenti, sconti, rimborsi). */
model AuditLog {
  id           String   @id @default(cuid())
  restaurantId String
  userId       String?
  action       String
  entityType   String?
  entityId     String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([restaurantId, createdAt])
  @@index([restaurantId, action])
}
