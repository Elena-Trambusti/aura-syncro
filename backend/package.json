{
  "name": "aura-syncro-backend",
  "version": "1.0.0",
  "description": "Backend API per Aura Syncro",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate && npx prisma migrate deploy && npx tsc",
    "start": "node dist/index.js",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate deploy",
    "db:push": "npx prisma db push",
    "db:seed": "tsx src/seed.ts",
    "db:seed-tenant": "tsx src/seed-tenant.ts",
    "db:seed-demo": "tsx scripts/seed-demo-tenant.ts",
    "test:flow": "tsx scripts/test-flow.ts",
    "db:recalculate-taxes": "tsx scripts/recalculate-order-taxes.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:legacy": "tsx --test src/lib/money.test.ts src/lib/taxEngine.test.ts src/lib/tipFiscal.test.ts src/lib/predictiveEngine.test.ts src/lib/fiscalInvoice.test.ts src/lib/menuStock.test.ts src/lib/posIntegration.test.ts src/lib/orderDiscount.test.ts src/lib/apiIdempotency.test.ts src/lib/fiscal/fiscalIntegrityChain.test.ts src/lib/fiscal/strategies/fiscalStrategies.test.ts src/lib/saasFatturaPaXml.test.ts src/lib/prismaTransactions.test.ts src/lib/splitSettlement.test.ts src/lib/tableReleaseGuard.test.ts",
    "stripe:verify": "tsx scripts/verify-stripe.ts",
    "stripe:sync-webhooks": "tsx scripts/sync-stripe-webhooks.ts",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@sentry/node": "^10.61.0",
    "@sentry/profiling-node": "^10.61.0",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "stripe": "^22.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
