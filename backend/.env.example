# Copia questo file in .env e compila i valori reali

# Supabase (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
JWT_SECRET="cambia-questo-con-una-stringa-segreta-lunga"
PORT=3001
FRONTEND_URL="http://localhost:5173,https://aura-syncro.vercel.app"
NODE_ENV="development"

# Sblocca funzioni Premium in locale (Report Fiscal, AI, ecc.) — solo development. "false" = paywall attivo
PREMIUM_DEV_UNLOCK="false"
# Sblocca piano Pro (CRM, AI, marketing…) in locale — solo development
PRO_PLAN_DEV_UNLOCK="false"

# Stripe - ottieni le chiavi su https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Endpoint webhook SaaS (Stripe Dashboard): POST https://tuo-dominio/api/webhooks/stripe
# Eventi consigliati: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted

# Chiave admin piattaforma — sblocco onboarding concierge (POST /api/admin/setup-complete)
ADMIN_API_KEY="inserisci-chiave-lunga-e-segreta"
