# Copia questo file in .env e compila i valori reali

# Supabase (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
JWT_SECRET="cambia-questo-con-una-stringa-segreta-lunga"
PORT=3001
FRONTEND_URL="http://localhost:5173,https://aurasyncro.com,https://www.aurasyncro.com"
NODE_ENV="development"

# Sblocca funzioni Premium in locale (Report Fiscal, AI, ecc.) — solo development. "false" = paywall attivo
PREMIUM_DEV_UNLOCK="false"
# Sblocca piano Pro (CRM, AI, marketing…) in locale — solo development
PRO_PLAN_DEV_UNLOCK="false"

# Stripe - ottieni le chiavi su https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price ID (Dashboard Stripe → Prodotti → prezzo, inizia con price_…)
STRIPE_PRICE_SETUP="price_..."
STRIPE_PRICE_SUBSCRIPTION="price_..."
# Endpoint webhook (Stripe Dashboard, TEST o LIVE):
# POST https://aura-syncro-s98ae.ondigitalocean.app/api/webhooks/stripe
# Eventi: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# Verifica: npm run stripe:verify --prefix backend
# Allinea webhook: npm run stripe:sync-webhooks --prefix backend
# Premium: POST /api/checkout (setup + €199/mo) → attiva hasActiveSubscription e planTier PRO via webhook

# Chiavi VAPID per Web Push (genera con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@tuo-dominio.it"

# Chiave admin piattaforma — sblocco onboarding concierge (POST /api/admin/setup-complete)
ADMIN_API_KEY="inserisci-chiave-lunga-e-segreta"

# SMTP — invio email marketing e notifiche (senza SMTP in dev i messaggi vanno in console)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Aura Syncro <noreply@tuo-dominio.it>"

# POS: "true" (default) simula addebito; "false" richiede payment intent Stripe reale
POS_USE_SIMULATION="true"

# Intervallo scheduler campagne marketing programmate (millisecondi, default 1 ora)
MARKETING_SCHEDULER_MS=3600000
