{
  "name": "aura-syncro",
  "private": true,
  "description": "Aura Syncro — monorepo frontend + backend",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm ci --include=dev --prefix backend && npm run build --prefix backend",
    "start": "npm run start --prefix backend",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./avvia-app.ps1",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "test": "vitest run && npm run test:legacy --prefix backend",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:business": "vitest run tests/business-logic",
    "test:api": "vitest run tests/business-logic/tenant-isolation.test.ts tests/business-logic/order-api-edge-cases.test.ts tests/business-logic/checkout-cash-api.test.ts",
    "test:unit": "npm run test:legacy --prefix backend",
    "test:e2e": "npm run test:e2e --prefix frontend",
    "test:all": "npm run test:vitest && npm run test:e2e --prefix frontend",
    "db:push": "npm run db:push --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:generate": "npm run db:generate --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "db:seed-tenant": "npm run db:seed-tenant --prefix backend",
    "db:studio": "npm run db:studio --prefix backend"
  },
  "dependencies": {
    "@sentry/node": "^10.61.0",
    "@sentry/react": "^10.61.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^3.24.2"
  }
}
