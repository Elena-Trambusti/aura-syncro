# URL del backend (es. http://localhost:3001 in locale, oppure l'URL di produzione)
AURA_WS_URL=https://api.aurasyncro.com

# Inserisci l'ID del ristorante (lo trovi nel DB o nell'URL della dashboard)
AURA_RESTAURANT_ID=inserisci-qui-il-tuo-id-ristorante

# Token pairing Print Agent (Impostazioni → Print Agent)
AURA_PRINT_TOKEN=inserisci-qui-il-token

# USB o NETWORK
PRINTER_TYPE=NETWORK
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
